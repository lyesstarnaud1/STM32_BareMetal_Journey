#include <stdint.h>
#include<stdio.h>
//creating a gpio typedef struct to access the registers of each GPIO port easy
typedef struct
{
volatile uint32_t MODER;
volatile uint32_t OTYPER;
volatile uint32_t OSPEEDR;
volatile uint32_t PUPDR;
volatile uint32_t IDR;
volatile uint32_t ODR;
volatile uint32_t BSRR;
volatile uint32_t LCKR;
volatile uint32_t AFRL;
volatile uint32_t AFRH;
 }GPIO;

int main(void)
{

	volatile uint32_t *RCC_AHB1ENR  =(uint32_t*) 0x40023830;
    //creating a pointer of type struct GPIO and assigning the adress of GPIOA from rm
	volatile GPIO *GPIOA =(GPIO*)0x40020000;
	//enabling the clock for port A
	*RCC_AHB1ENR |= (1<<0);
	//Clearing the 10th & 11th pins to make pin PA5 as output
    GPIOA->MODER &= ~(3<<10);
    GPIOA->MODER |= (1<<10);

	/* Loop forever */
	while(1)
	{
		//Set the the pin
		GPIOA->BSRR = (1<<5); //the BSRR is write only register we set/reset directly using = xx
		printf("LED is ON\n");
		for(volatile uint32_t i=0;i<500000;i++);
		//reset the pin : from 16-31 are reset bits for each pin
		GPIOA->BSRR = (1<<21);
		printf("LED is OFF\n");
		for(volatile uint32_t i=0;i<500000;i++);
	}
	return 0;
}
