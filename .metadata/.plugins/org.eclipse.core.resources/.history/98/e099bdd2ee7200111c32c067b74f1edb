#include <stdint.h>
#include<stdio.h>
//creating a gpio typedef struct to access the registers of each GPIO port easy
typedef struct
{
uint32_t MODER;
uint32_t OTYPER;
uint32_t OSPEEDR;
uint32_t PUPDR;
uint32_t IDR;
uint32_t ODR;
uint32_t BSRR;
uint32_t LCKR;
uint32_t AFRL;
uint32_t AFRH;
 }GPIO;

int main(void)
{
    //creating a pointer of type struct GPIO and assigning the adress of GPIOA from rm
	volatile GPIO *GPIOA =(GPIO*)0x40020000;
	//Clearing the 10th & 11th pins to make pin PA5 as output
    GPIOA->MODER &= ~(3<<10);

	/* Loop forever */
	while(1)
	{
		//Set the the pin
		GPIOA->BSRR |= (1<<5);
		for(volatile uint32_t i=0;i>500000;i++);
		//reset the pin
		GPIOA->BSSR |= (1<<21);
	}
	return 0;
}
