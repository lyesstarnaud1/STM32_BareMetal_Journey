#include <stdint.h>
#include <stdio.h>

//here we are working on port D to use external pins with Leds breadboard
// change to port c to use 12th pin or pin 2 in port d
int main(void)
{
	volatile uint32_t *p_RCC_AHB1ENR =(uint32_t*) 0x40023830 ; //enabling the port "setting the clock on"
	volatile uint32_t *p_gpioC_moder =(uint32_t *)0x40020800  ;//chosing the mode of the pin input or output...
	volatile  uint32_t *p_gpioC_odr =(uint32_t *)0x40020814 ; //putting the data output on /off ...etc

   //enabling the clock for port D
    *p_RCC_AHB1ENR |= 0x04; // 0x00000004 or *p_RCC_AHB1ENR|=(1<<2) ;

    //setting the type to output
    //1- WE must clear both bits of the pin in this case pin 12 (24&25th bits)
    *p_gpioC_moder &= ~(3<<24);
    //2- setting the 24th bits to 1
    *p_gpioC_moder |= (1<<24);
  /* Loop forever */
	while(1){
  //toggling the 12th pins on port D
    *p_gpioC_odr ^= 0x1000; //toggle the pin on/off
	for(volatile uint32_t i=0;i<500000;i++);
	}
}
