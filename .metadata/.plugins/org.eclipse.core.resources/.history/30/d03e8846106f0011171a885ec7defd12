#include <stdint.h>
#include <stdio.h>
//in this exercise we're reading a button statues to trigger something
//and we will apply the CONST qualifier
//here we are working on port c to use external pins with Leds breadboard



int main(void)
{
	// change to port c to use 12th pin or pin 2 in port d
		volatile uint32_t *const p_RCC_AHB1ENR =(uint32_t*) 0x40023830 ; //enabling the port "setting the clock on"
		volatile uint32_t *const p_gpioC_moder =(uint32_t *)0x40020800  ;//chosing the mode of the pin input or output...
		volatile uint32_t *const p_gpioA_moder =(uint32_t *)0x40020000  ;//chosing the mode of the pin input or output
	//	volatile  uint32_t *const p_gpioC_odr =(uint32_t *)0x40020814 ; //putting the data output on /off ...etc
		volatile  uint32_t *const p_gpioC_idr =(uint32_t *)0x40020810 ;//reading the statues of the PC13 BUTTON pin
		volatile  uint32_t *const p_gpioA_odr =(uint32_t *)0x40020014 ;//to control the power in PA5 LED pin
   //enabling the clock for port C & A
    *p_RCC_AHB1ENR |= 0x05; // 0x00000004 or *p_RCC_AHB1ENR|=(1<<2) ;

    //setting the type to output OR output
    //1- WE must clear both bits of the pin in this case pin  pin 13 26th/27th bits to make it input
    *p_gpioC_moder &= ~(3<<26);
    // making the 5th pin of port A as output
    *p_gpioA_moder &= ~(3<<10);
    *p_gpioA_moder |= (1<<10);
  /* Loop forever */
	while(1)
	{
		//reading the 12th pins on port c

			 uint16_t status = (uint16_t) *p_gpioC_idr & (1<<13);

			    if(status == 8192)
			    {
			    	printf("pin is OFF\n");
			    	*p_gpioA_odr |= (1<<5);
			    }

			    else
			    	{
			    	printf("pin is ON\n");
			    	*p_gpioA_odr &= ~(1<<5);
			    	}
	}
	return 0;
}
